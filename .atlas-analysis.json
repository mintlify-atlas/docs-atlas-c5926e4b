  "keyFeatures": [
    "Restores the classic YouTube Hitchhiker layout (2013–2020) as a server-side proxy",
    "PHP-based server application — browser and extension independent",
    "InnerTube API integration for YouTube data fetching",
    "Twig-based HTML templating engine with SPF (Structured Page Fragments) support",
    "Custom async/Promise engine for single-threaded asynchronous PHP execution",
    "Comprehensive configuration system with appearance, experiments, and advanced options",
    "Internationalization (i18n) support for multiple languages",
    "Return YouTube Dislike API integration",
    "MVC architecture with controllers, models, and Twig views",
    "Built-in debugger and profiler tools"
  ],
  "publicApiSurface": [
    "Config::getConfigProp(string $path)",
    "Network::innertubeRequest(string $action, array $body, string $clientName, string $clientVersion)",
